async function seedDefaultWorkouts() {
  const count = await countWorkouts();
  if (count === 0) {
    for (const w of DEFAULT_WORKOUTS) {
      await createWorkout({ ...w, isLibrary: true });
    }
    console.log("[Seed] Default workouts inserted.");
  }
}

// Run seed on startup
seedDefaultWorkouts().catch(console.error);

// ─── App Router ───────────────────────────────────────────────────────────────
export const appRouter = router({
  system: systemRouter,

  // ── OAuth auth (kept for compatibility) ──────────────────────────────────
  auth: router({
    me: publicProcedure.query((opts) => opts.ctx.user),
    logout: publicProcedure.mutation(({ ctx }) => {
      const cookieOptions = getSessionCookieOptions(ctx.req);
      ctx.res.clearCookie(COOKIE_NAME, { ...cookieOptions, maxAge: -1 });
      return { success: true } as const;
    }),
  }),

  // ── Athlete custom auth ───────────────────────────────────────────────────
  athleteAuth: router({
    login: publicProcedure
      .input(z.object({ username: z.string(), password: z.string() }))
      .mutation(async ({ input, ctx }) => {
        const athlete = await getAthleteByUsername(input.username);
        if (!athlete) {
          throw new TRPCError({ code: "UNAUTHORIZED", message: "Invalid username or password" });
        }
        const valid = await bcrypt.compare(input.password, athlete.passwordHash);
        if (!valid) {
          throw new TRPCError({ code: "UNAUTHORIZED", message: "Invalid username or password" });
        }
        const token = await signAthleteToken(athlete.id, athlete.role);
        const isSecure = ctx.req.protocol === "https" || ctx.req.headers["x-forwarded-proto"] === "https";
        ctx.res.cookie(ATHLETE_COOKIE, token, {
          httpOnly: true,
          secure: isSecure,
          sameSite: isSecure ? "none" : "lax",
          maxAge: 7 * 24 * 60 * 60 * 1000,
          path: "/",
        });
        return {
          id: athlete.id,
          name: athlete.name,
          username: athlete.username,
          role: athlete.role,
          sportMode: athlete.sportMode,
        };
      }),

    me: publicProcedure.query(async ({ ctx }) => {
      const token = getAthleteToken(ctx.req);
      if (!token) return null;
      const payload = await verifyAthleteToken(token);
      if (!payload) return null;
      const athlete = await getAthleteById(payload.athleteId);
      if (!athlete || !athlete.isActive) return null;
      return {
        id: athlete.id,
        name: athlete.name,
        username: athlete.username,
        role: athlete.role,
        sportMode: athlete.sportMode,
      };
    }),

    logout: publicProcedure.mutation(({ ctx }) => {
      const isSecure = ctx.req.protocol === "https" || ctx.req.headers["x-forwarded-proto"] === "https";
      ctx.res.clearCookie(ATHLETE_COOKIE, {
        httpOnly: true,
        secure: isSecure,
        sameSite: isSecure ? "none" : "lax",
        path: "/",
        maxAge: -1,
      });
      return { success: true };
    }),

    updateSportMode: publicProcedure
      .input(z.object({ sportMode: z.enum(["track", "xc"]) }))
      .mutation(async ({ input, ctx }) => {
        const token = getAthleteToken(ctx.req);
        if (!token) throw new TRPCError({ code: "UNAUTHORIZED" });
        const payload = await verifyAthleteToken(token);
        if (!payload) throw new TRPCError({ code: "UNAUTHORIZED" });
        await updateAthleteSportMode(payload.athleteId, input.sportMode);
        return { success: true };
      }),
  }),

  // ── Athletes (admin only) ─────────────────────────────────────────────────
  athletes: router({
    list: publicProcedure.query(async ({ ctx }) => {
      // Allow access from athlete-admin cookie
      const token = getAthleteToken(ctx.req);
      if (token) {
        const payload = await verifyAthleteToken(token);
        if (payload?.role === "admin") return getAllAthletes();
      }
      if (ctx.user?.role !== "admin") throw new TRPCError({ code: "FORBIDDEN" });
      return getAllAthletes();
    }),

    create: publicProcedure
      .input(
        z.object({
          name: z.string().min(1),
          username: z.string().min(3),
          password: z.string().min(6),
        })
