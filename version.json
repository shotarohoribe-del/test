const ATHLETE_COOKIE = "wd_athlete_session";

// ─── Cookie helper ──────────────────────────────────────────────────────────
function getAthleteToken(req: { cookies?: Record<string, string>; headers: Record<string, string | string[] | undefined> }): string | undefined {
  // Try req.cookies first (populated by cookie-parser if present)
  if (req.cookies?.[ATHLETE_COOKIE]) return req.cookies[ATHLETE_COOKIE];
  // Fall back to parsing the Cookie header directly
  const cookieHeader = req.headers["cookie"];
  if (!cookieHeader) return undefined;
  const header = Array.isArray(cookieHeader) ? cookieHeader[0] : cookieHeader;
  const parsed = parseCookies(header ?? "");
  return parsed[ATHLETE_COOKIE];
}

// ─── JWT helpers for custom athlete auth ─────────────────────────────────────
const JWT_SECRET = new TextEncoder().encode(
  process.env.JWT_SECRET || "westmont-distance-secret-key-2024"
);

async function signAthleteToken(athleteId: number, role: string) {
  return new jose.SignJWT({ athleteId, role })
    .setProtectedHeader({ alg: "HS256" })
    .setExpirationTime("7d")
    .sign(JWT_SECRET);
}

async function verifyAthleteToken(token: string) {
  try {
    const { payload } = await jose.jwtVerify(token, JWT_SECRET);
    return payload as { athleteId: number; role: string };
  } catch {
    return null;
  }
}

// ─── Admin guard middleware ───────────────────────────────────────────────────
const adminProcedure = protectedProcedure.use(async ({ ctx, next }) => {
  // Check if the user is the athlete-admin via cookie
  const athleteCookie = getAthleteToken(ctx.req);
  if (athleteCookie) {
    const payload = await verifyAthleteToken(athleteCookie);
    if (payload?.role === "admin") {
      return next({ ctx: { ...ctx, athleteId: payload.athleteId, athleteRole: "admin" } });
    }
  }
  if (ctx.user?.role !== "admin") {
    throw new TRPCError({ code: "FORBIDDEN", message: "Admin access required" });
  }
  return next({ ctx });
});

